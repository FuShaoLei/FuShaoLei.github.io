    &lt;span style=&#34;color:#268bd2&#34;&gt;private&lt;/span&gt; &lt;span style=&#34;color:#268bd2&#34;&gt;class&lt;/span&gt; &lt;span style=&#34;color:#268bd2&#34;&gt;TwoViewHolder&lt;/span&gt; &lt;span style=&#34;color:#268bd2&#34;&gt;extends&lt;/span&gt; RecyclerView&lt;span style=&#34;color:#719e07&#34;&gt;.&lt;/span&gt;ViewHolder&lt;span style=&#34;color:#719e07&#34;&gt;{&lt;/span&gt;
        &lt;span style=&#34;color:#268bd2&#34;&gt;private&lt;/span&gt; ImageView mAvator&lt;span style=&#34;color:#719e07&#34;&gt;;&lt;/span&gt;
        &lt;span style=&#34;color:#268bd2&#34;&gt;private&lt;/span&gt; TextView mName&lt;span style=&#34;color:#719e07&#34;&gt;;&lt;/span&gt;
        &lt;span style=&#34;color:#268bd2&#34;&gt;private&lt;/span&gt; Button mButton&lt;span style=&#34;color:#719e07&#34;&gt;;&lt;/span&gt;

        &lt;span style=&#34;color:#268bd2&#34;&gt;public&lt;/span&gt; &lt;span style=&#34;color:#268bd2&#34;&gt;TwoViewHolder&lt;/span&gt;&lt;span style=&#34;color:#719e07&#34;&gt;(&lt;/span&gt;&lt;span style=&#34;color:#268bd2&#34;&gt;@NonNull&lt;/span&gt; View itemView&lt;span style=&#34;color:#719e07&#34;&gt;)&lt;/span&gt; &lt;span style=&#34;color:#719e07&#34;&gt;{&lt;/span&gt;
            &lt;span style=&#34;color:#268bd2&#34;&gt;super&lt;/span&gt;&lt;span style=&#34;color:#719e07&#34;&gt;(&lt;/span&gt;itemView&lt;span style=&#34;color:#719e07&#34;&gt;);&lt;/span&gt;
            mAvator &lt;span style=&#34;color:#719e07&#34;&gt;=&lt;/span&gt; itemView&lt;span style=&#34;color:#719e07&#34;&gt;.&lt;/span&gt;findViewById&lt;span style=&#34;color:#719e07&#34;&gt;(&lt;/span&gt;R&lt;span style=&#34;color:#719e07&#34;&gt;.&lt;/span&gt;id&lt;span style=&#34;color:#719e07&#34;&gt;.&lt;/span&gt;iv_avator&lt;span style=&#34;color:#719e07&#34;&gt;);&lt;/span&gt;
            mName &lt;span style=&#34;color:#719e07&#34;&gt;=&lt;/span&gt; itemView&lt;span style=&#34;color:#719e07&#34;&gt;.&lt;/span&gt;findViewById&lt;span style=&#34;color:#719e07&#34;&gt;(&lt;/span&gt;R&lt;span style=&#34;color:#719e07&#34;&gt;.&lt;/span&gt;id&lt;span style=&#34;color:#719e07&#34;&gt;.&lt;/span&gt;tv_name&lt;span style=&#34;color:#719e07&#34;&gt;);&lt;/span&gt;
            mButton &lt;span style=&#34;color:#719e07&#34;&gt;=&lt;/span&gt; itemView&lt;span style=&#34;color:#719e07&#34;&gt;.&lt;/span&gt;findViewById&lt;span style=&#34;color:#719e07&#34;&gt;(&lt;/span&gt;R&lt;span style=&#34;color:#719e07&#34;&gt;.&lt;/span&gt;id&lt;span style=&#34;color:#719e07&#34;&gt;.&lt;/span&gt;btn_btn&lt;span style=&#34;color:#719e07&#34;&gt;);&lt;/span&gt;
        &lt;span style=&#34;color:#719e07&#34;&gt;}&lt;/span&gt;
    &lt;span style=&#34;color:#719e07&#34;&gt;}&lt;/span&gt;
&lt;span style=&#34;color:#719e07&#34;&gt;}&lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p&gt;里面还遇到了一个问题，未解决&lt;/p&gt;
&lt;div class=&#34;highlight&#34;&gt;&lt;pre style=&#34;color:#93a1a1;background-color:#002b36;-moz-tab-size:4;-o-tab-size:4;tab-size:4&#34;&gt;&lt;code class=&#34;language-java&#34; data-lang=&#34;java&#34;&gt;&lt;span style=&#34;color:#586e75&#34;&gt;//                view  = View.inflate(parent.getContext(), R.layout.item_type_two,null);
&lt;/span&gt;&lt;span style=&#34;color:#586e75&#34;&gt;&lt;/span&gt;                view &lt;span style=&#34;color:#719e07&#34;&gt;=&lt;/span&gt; LayoutInflater&lt;span style=&#34;color:#719e07&#34;&gt;.&lt;/span&gt;from&lt;span style=&#34;color:#719e07&#34;&gt;(&lt;/span&gt;parent&lt;span style=&#34;color:#719e07&#34;&gt;.&lt;/span&gt;getContext&lt;span style=&#34;color:#719e07&#34;&gt;()).&lt;/span&gt;inflate&lt;span style=&#34;color:#719e07&#34;&gt;(&lt;/span&gt;R&lt;span style=&#34;color:#719e07&#34;&gt;.&lt;/span&gt;layout&lt;span style=&#34;color:#719e07&#34;&gt;.&lt;/span&gt;item_type_two&lt;span style=&#34;color:#719e07&#34;&gt;,&lt;/span&gt;parent&lt;span style=&#34;color:#719e07&#34;&gt;,&lt;/span&gt;&lt;span style=&#34;color:#cb4b16&#34;&gt;false&lt;/span&gt;&lt;span style=&#34;color:#719e07&#34;&gt;);&lt;/span&gt;
&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p&gt;这两个方法都能弄出视图来，可是，第一个方法呈现的视图是紧凑的，也就是我的&lt;code&gt;margin&lt;/code&gt;值是无效的&amp;hellip;.留个坑&lt;/p&gt;- https://fushaolei.github.io/post/recyclerview-multi-style/ - </description>
